<%= form_with(model: exercise, url:[@course, exercise], class: "contents") do |form| %>
  <% if exercise.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(exercise.errors.count, "error") %> prohibited this exercise from being saved:</h2>

      <ul>
        <% exercise.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title , "titre de exercice" %>
    <br>
      <small>je suis le message</small>
      <%= form.text_field :title, placeholder:"Ajouter le titre de exercice ...", class: "block rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>


  <div class="inline">
    <%= form.submit "Enregistrez", class: "py-2 px-4 bg-blue-600 text-white font-bold rounded" %>
  </div>
<% end %>
